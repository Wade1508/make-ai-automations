        {
            "id": 2,
            "module": "google-calendar:createAnEvent",
            "version": 5,
            "parameters": {
                "__IMTCONN__": 9380966
            },
            "filter": {
                "name": "Seulement si à relancer",
                "conditions": [
                    [
                        {
                            "a": "{{1.`5`}}",
                            "b": "À relancer",
                            "o": "text:equal"
                        }
                    ]
                ]
            },
            "mapper": {
                "end": "{{addHours(addDays(1.`4`; 7); 1)}}",
                "start": "{{addDays(1.`4`; 7)}}",
                "select": "detail",
                "summary": "Relancer [{{1.`0`}}]",
                "calendar": "goradia1508@gmail.com",
                "visibility": "default",
                "allDayEvent": false,
                "description": "Envoyer un mail à [{{1.`2`}}]",
                "transparency": "opaque",
                "conferenceDate": false,
                "guestPermissions": {
                    "guestsCanModify": false,
                    "guestsCanInviteOthers": true,
                    "guestsCanSeeOtherGuests": true
                }
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "expect": {
                        "select": {
                            "label": "In Detail"
                        },
                        "colorId": {
                            "mode": "chose"
                        },
                        "calendar": {
                            "mode": "chose",
                            "label": "goradia1508@gmail.com (Primary Calendar)"
                        },
                        "attendees": {
                            "mode": "chose"
                        },
                        "eventType": {
                            "mode": "chose",
                            "label": "Empty"
                        },
                        "overrides": {
                            "mode": "chose"
                        },
                        "recurrence": {
                            "mode": "chose"
                        },
